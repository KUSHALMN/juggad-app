# Google Cloud & Firebase Settings
# Change 'jugaad-prod' to your actual Firebase project ID if different
GOOGLE_CLOUD_PROJECT=jugaad-prod

# For local development ONLY. Point this to your generated adc.json or service account key.
# If you ran `gcloud auth application-default login`, point it to that path, for example:
# GOOGLE_APPLICATION_CREDENTIALS=C:\Users\HP\AppData\Roaming\gcloud\application_default_credentials.json
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\HP\AppData\Roaming\gcloud\application_default_credentials.json

# Internal Microservice Security
# This is the expected audience string for OIDC tokens passed between your internal services.
INTERNAL_SERVICE_AUDIENCE=jugaad-internal-apis

# --- Other Required API Keys (Fill these in!) ---
# MSG91
MSG91_API_KEY=your_msg91_api_key_here
MSG91_FLOW_ID_OTP=your_msg91_flow_id_here

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
