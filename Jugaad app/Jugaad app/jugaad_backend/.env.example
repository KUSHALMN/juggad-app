# GCP / Firebase
GOOGLE_CLOUD_PROJECT=jugaad-prod
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Pub/Sub
PUBSUB_TOPIC=jugaad-job-events
PUBSUB_DLQ_TOPIC=jugaad-dlq

# Upstash QStash
QSTASH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXX
QSTASH_CURRENT_SIGNING_KEY=XXXXXXXXXXXXXXXXXXXXXXXX
QSTASH_NEXT_SIGNING_KEY=XXXXXXXXXXXXXXXXXXXXXXXX

# QStash callback URLs go through the API Gateway (FIX A)
# Format: https://<gateway-host>/internal/<service>/<endpoint>
API_GATEWAY_HOST=https://api.jugaad.app
JOB_SERVICE_TIMEOUT_URL=https://api.jugaad.app/internal/job/timeout
SCHEDULER_ACTIVATE_URL=https://api.jugaad.app/internal/scheduler/activate-scheduled

# GCP service account for OIDC verification
GCP_SERVICE_ACCOUNT_EMAIL=jugaad-sa@jugaad-prod.iam.gserviceaccount.com

# Razorpay
RAZORPAY_KEY_ID=rzp_live_XXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# SMS
MSG91_AUTH_KEY=XXXXXXXXXXXXXXXXXXXXXXXX
MSG91_TEMPLATE_ID=XXXXXXXXXXXXXXXXXXXXXXXX

# Pilot geography (FIX 5 from v2 — never hardcode in source)
PILOT_LAT_CENTER=12.3052
PILOT_LNG_CENTER=76.6552

# Deploy region (FIX 5 from v2)
GCP_REGION=asia-south1

# Service identity
SERVICE_NAME=request_service
PORT=8080
ENV=production
