rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()            { return request.auth != null; }
    function isUser(uid)         { return isAuth() && request.auth.uid == uid; }
    function isWorker(wid)       { return isAuth() && request.auth.uid == wid; }

    match /jobs/{jobId} {
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.user_id ||
         request.auth.uid == resource.data.worker_id);
      allow write: if false;

      match /outbox/{eventId}   { allow read, write: if false; }
      match /reviews/{reviewId} {
        allow read: if isAuth() &&
          (request.auth.uid == resource.data.user_id ||
           request.auth.uid == resource.data.worker_id);
        allow write: if false;
      }
    }

    match /workers/{workerId} {
      allow read: if isAuth();
      allow update: if isWorker(workerId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["fcm_token","fcm_updated_at"]);
      allow create, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if isUser(userId);
    }

    match /scheduled_jobs/{jobId} {
      allow read: if isAuth() && request.auth.uid == resource.data.user_id;
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow read: if isAuth() && request.auth.uid == resource.data.user_id;
      allow write: if false;
    }

    match /notifications/{notifId}  { allow read, write: if false; }
    match /payout_requests/{id}     { allow read, write: if false; }
    match /admin_log/{id}           { allow read, write: if false; }

    match /{document=**} { allow read, write: if false; }
  }
}
