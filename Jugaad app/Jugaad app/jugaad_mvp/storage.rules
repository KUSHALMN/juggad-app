rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Worker uploads (ID, selfie, certificates)
    match /workers/{workerId}/{allPaths=**} {
      // Anyone authenticated can view worker assets (like avatars)
      allow read: if request.auth != null;
      // Only the worker themselves can upload/modify their directory
      allow write: if request.auth != null && request.auth.uid == workerId;
    }
    
    // User uploads (Avatars, job images if applicable)
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
